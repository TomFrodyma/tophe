# Tophe environment. Copy to .env.local and fill in.
#
#   cp .env.example .env.local
#
# The values below work with the local docker-compose stack
# (`docker compose up -d` gives you Postgres + MinIO).

# ----- Core (required) -----

# Postgres. The default matches docker-compose.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tophe"

# Session signing secret, 32 random bytes:
BETTER_AUTH_SECRET=""

# The app's public URL (auth callbacks + links in notifications).
NEXT_PUBLIC_SAAS_URL="http://localhost:3000"

# ----- AI (configure at least one provider) -----

# Recommended: a self-hosted model server (Ollama, LM Studio, llama.cpp, vLLM).
# Every model on the server is auto-discovered into the chat's model picker.
LOCAL_AI_BASE_URL="http://localhost:11434/v1"
# LOCAL_AI_API_KEY=""
# LOCAL_AI_MODELS=""

# And/or the Claude API:
# ANTHROPIC_API_KEY=""

# And/or OpenAI - or any other hosted OpenAI-compatible provider
# (OpenRouter, Groq, Mistral, ...) by also setting its base URL:
# OPENAI_API_KEY=""
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODELS=""

# Optional model pins. Defaults: first configured model / per-task picks.
# AI_DEFAULT_MODEL=""
# AI_TASK_MODEL=""

# ----- Storage -----

# Where the storage module writes files.
STORAGE_VOLUME_PATH="./.local-storage"

# S3-compatible storage for avatars only. Defaults match the docker-compose MinIO.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
NEXT_PUBLIC_AVATARS_BUCKET_NAME="avatars"

# ----- Mail (optional; notification + auth emails) -----

# Resend is the wired-up provider (packages/mail/provider has alternatives).
# Without a key, emails just don't send - the app works fine.
# RESEND_API_KEY=""

# ----- Web Push (browser/PWA notifications) -----

# Zero-config: the key pair is generated automatically on first use and kept
# in the database. Set these only to bring your own keys.
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:you@example.com"

# ----- Integrations -----

# AES-256-GCM key for encrypted calendar (ICS) URLs, 32 random bytes base64
# (same command as BETTER_AUTH_SECRET). NEVER rotate it - stored integration
# URLs become undecryptable.
CALENDAR_INTEGRATION_SECRET=""

# Bearer token the cron endpoints require (see AGENTS.md for the cron setup).
CRON_SECRET=""
